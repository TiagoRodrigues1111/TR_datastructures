/* 2 defines */
/*****************************************************/

/* ------------------------------------------------------------------
 * 2.1 Version numbers
 * These are automatically populated by CMake from the project()
 * VERSION field in the root CMakeLists.txt
 * ------------------------------------------------------------------ */
#define TR_VERSION_MAJOR @PROJECT_VERSION_MAJOR@
#define TR_VERSION_MINOR @PROJECT_VERSION_MINOR@
#define TR_VERSION_PATCH @PROJECT_VERSION_PATCH@
#define TR_VERSION_STRING "@PROJECT_VERSION@"


/* ------------------------------------------------------------------
 * 2.2 Version encoding
 * Encodes the full version into a single integer for easy comparison
 * e.g. version 1.2.3 becomes 0x00010203
 * Usage: #if TR_VERSION >= TR_VERSION_ENCODE(1, 2, 0)
 * ------------------------------------------------------------------ */
#define TR_VERSION_ENCODE(major, minor, patch) \
    (((major) << 16) | ((minor) << 8) | (patch))

#define TR_VERSION \
    TR_VERSION_ENCODE(TR_VERSION_MAJOR, TR_VERSION_MINOR, TR_VERSION_PATCH)


/* ------------------------------------------------------------------
 * 2.3 Version check macro
 * Returns 1 if the current version is at least major.minor.patch
 * Usage: #if TR_VERSION_AT_LEAST(1, 2, 0)
 * ------------------------------------------------------------------ */
#define TR_VERSION_AT_LEAST(major, minor, patch) \
    (TR_VERSION >= TR_VERSION_ENCODE(major, minor, patch))


