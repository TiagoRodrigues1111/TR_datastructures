{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },

    "configurePresets": [

        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_C_STANDARD": "11",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },

        {
            "name": "debug",
            "displayName": "Debug",
            "description": "Debug build with no optimisations",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "TR_BUILD_TESTS": "ON"
            }
        },

        {
            "name": "release",
            "displayName": "Release",
            "description": "Release build with optimisations",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },

        {
            "name": "debug-makefiles",
            "displayName": "Debug (Unix Makefiles)",
            "description": "Debug build using Unix Makefiles",
            "inherits": "debug",
            "generator": "Unix Makefiles"
        },

        {
            "name": "release-makefiles",
            "displayName": "Release (Unix Makefiles)",
            "description": "Release build using Unix Makefiles",
            "inherits": "release",
            "generator": "Unix Makefiles"
        },

        {
            "name": "asan",
            "displayName": "AddressSanitizer",
            "description": "Debug build with AddressSanitizer enabled",
            "inherits": "debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_FLAGS": "-fsanitize=address -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=address"
            }
        },

        {
            "name": "ubsan",
            "displayName": "UndefinedBehaviourSanitizer",
            "description": "Debug build with UBSan enabled",
            "inherits": "debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_FLAGS": "-fsanitize=undefined -fno-omit-frame-pointer",
                "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=undefined"
            }
        },

        {
            "name": "coverage",
            "displayName": "Coverage",
            "description": "Debug build with coverage instrumentation enabled",
            "inherits": "debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE":  "Debug",
                "TR_BUILD_TESTS":    "ON",
                "CMAKE_C_FLAGS":     "--coverage -fprofile-arcs -ftest-coverage",
                "CMAKE_EXE_LINKER_FLAGS": "--coverage"
            }
        }

    ],

    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Build Debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "displayName": "Build Release",
            "configurePreset": "release"
        },
        {
            "name": "asan",
            "displayName": "Build ASan",
            "configurePreset": "asan"
        },
        {
            "name": "ubsan",
            "displayName": "Build UBSan",
            "configurePreset": "ubsan"
        },
        {
            "name": "coverage",
            "displayName": "Build Coverage",
            "configurePreset": "coverage"
        }
    ],

    "testPresets": [
        {
            "name": "debug",
            "displayName": "Test Debug",
            "configurePreset": "debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "asan",
            "displayName": "Test ASan",
            "configurePreset": "asan",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "ubsan",
            "displayName": "Test UBSan",
            "configurePreset": "ubsan",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}