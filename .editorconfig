root = true

# ------------------------------------------------------------------
# DEFAULT - all files
# ------------------------------------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# ------------------------------------------------------------------
# C SOURCE & HEADERS
# ------------------------------------------------------------------
[*.{c,h}]
indent_style = space
indent_size = 8

# ------------------------------------------------------------------
# CMAKE
# ------------------------------------------------------------------
[{CMakeLists.txt,*.cmake,*.cmake.in}]
indent_style = space
indent_size = 4

# ------------------------------------------------------------------
# YAML / CI
# ------------------------------------------------------------------
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# ------------------------------------------------------------------
# MARKDOWN
# ------------------------------------------------------------------
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ------------------------------------------------------------------
# SCRIPTS
# ------------------------------------------------------------------
[*.sh]
indent_style = space
indent_size = 4

[*.{bat,cmd,ps1}]
end_of_line = crlf
indent_style = space
indent_size = 4

# ------------------------------------------------------------------
# JSON
# ------------------------------------------------------------------
[*.json]
indent_style = space
indent_size = 2