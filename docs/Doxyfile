# ------------------------------------------------------------------
# Doxyfile
# Doxygen configuration for TR_datastructures
# ------------------------------------------------------------------

#---------------------------------------------------------------------------
# Project information
#---------------------------------------------------------------------------
PROJECT_NAME            = "TR_datastructures"
PROJECT_NUMBER          = "0.1.0"
PROJECT_BRIEF           = "A generic C data structures library"
PROJECT_LOGO            =
OUTPUT_DIRECTORY        = docs/output
CREATE_SUBDIRS          = NO

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                   = include \
                          README.md
INPUT_ENCODING          = UTF-8
FILE_PATTERNS           = *.h \
                          *.md
RECURSIVE               = YES
EXCLUDE                 = build \
                          docs/output
USE_MDFILE_AS_MAINPAGE  = README.md

#---------------------------------------------------------------------------
# Output formats
#---------------------------------------------------------------------------
GENERATE_HTML           = YES
HTML_OUTPUT             = html
HTML_COLORSTYLE         = DARK
GENERATE_LATEX          = NO
GENERATE_MAN            = NO

#---------------------------------------------------------------------------
# Source browsing
#---------------------------------------------------------------------------
SOURCE_BROWSER          = NO
INLINE_SOURCES          = NO
STRIP_CODE_COMMENTS     = NO
REFERENCED_BY_RELATION  = YES
REFERENCES_RELATION     = YES

#---------------------------------------------------------------------------
# Extraction settings
#---------------------------------------------------------------------------
EXTRACT_ALL             = YES
EXTRACT_PRIVATE         = NO
EXTRACT_STATIC          = NO
EXTRACT_LOCAL_CLASSES   = NO
HIDE_UNDOC_MEMBERS      = YES
HIDE_UNDOC_CLASSES      = YES
INTERNAL_DOCS           = NO

#---------------------------------------------------------------------------
# Preprocessing
#---------------------------------------------------------------------------
ENABLE_PREPROCESSING    = YES
MACRO_EXPANSION         = YES
EXPAND_ONLY_PREDEF      = YES
PREDEFINED              = TR_API= \
                          TR_NODISCARD= \
                          TR_DEPRECATED(x)= \
                          TR_INTERNAL= \
                          "__attribute__(x)="

#---------------------------------------------------------------------------
# Dot / graphs
#---------------------------------------------------------------------------
HAVE_DOT                = NO
CLASS_DIAGRAMS          = NO

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
QUIET                   = NO
WARNINGS                = YES
WARN_IF_UNDOCUMENTED    = YES
WARN_IF_DOC_ERROR       = YES
WARN_NO_PARAMDOC        = YES
WARN_LOGFILE            = docs/doxygen_warnings.log

#---------------------------------------------------------------------------
# Aliases
#---------------------------------------------------------------------------
ALIASES                 = "purpose=@brief" \
                          "returns=@return"